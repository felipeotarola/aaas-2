# Shared Supabase project (self-hosted or cloud)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Minimal OpenClaw runtime for single-VPS deployments
# OPENCLAW_GATEWAY_TOKEN=<gateway-token>
#
# Optional OpenClaw config resolution overrides
# OPENCLAW_HOME=/home/node/.openclaw
# OPENCLAW_CONFIG_PATH=/var/lib/openclaw/openclaw.json
# OPENCLAW_AGENTS_ROOT=/home/node/.openclaw/agents
# OPENCLAW_CONFIG_BRIDGE_URL=http://127.0.0.1:4311/api/openclaw/config
# OPENCLAW_CONFIG_BRIDGE_TOKEN=<optional-config-bridge-bearer-token>
# OPENCLAW_CLI_PATH=/usr/local/bin/openclaw
# OPENCLAW_AGENT_BRIDGE_URL=https://api.felipeotarola.com/api/openclaw/assistant-chat/{agentId}
# OPENCLAW_AGENT_BRIDGE_TOKEN=<optional-bridge-bearer-token>
# OPENCLAW_GATEWAY_WS_URL=ws://127.0.0.1:18789/ws
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_HOST=127.0.0.1
# OPENCLAW_GATEWAY_PORT=18789
