# Shared Supabase project (self-hosted or cloud)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Optional OpenClaw config resolution (recommended in production)
# OPENCLAW_HOME=/home/node/.openclaw
# OPENCLAW_CONFIG_PATH=/home/node/.openclaw/openclaw.json
# OPENCLAW_AGENTS_ROOT=/home/node/.openclaw/agents
# OPENCLAW_CONFIG_BRIDGE_URL=http://127.0.0.1:4311/api/openclaw/config
